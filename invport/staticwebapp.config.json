{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/_next/*", "/logo/*", "*.html"]
  },
  "routes": [
    {
      "route": "/.auth/*",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/loggedout.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/loggedout",
      "serve": "/loggedout.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/401.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/403.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/404.html",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/_next/static/*",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "route": "/api/*",
      "allowedRoles": ["inventoryuser"]
    },
    {
      "route": "/*",
      "allowedRoles": ["inventoryuser"]
    }
  ],
  "responseOverrides": {
    "401": {
      "redirect": "/.auth/login/aad",
      "statusCode": 302
    },
    "403": {
      "statusCode": 403,
      "rewrite": "/403.html"
    },
    "404": {
      "statusCode": 404,
      "rewrite": "/404.html"
    }
  },
  "globalHeaders": {
    "cache-control": "no-cache, no-store, must-revalidate",
    "strict-transport-security": "max-age=31536000; includeSubDomains",
    "x-content-type-options": "nosniff",
    "x-frame-options": "DENY",
    "referrer-policy": "strict-origin-when-cross-origin",
    "permissions-policy": "geolocation=(), microphone=(), camera=()",
    "content-security-policy": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline' https://*.azurestaticapps.net https://*.azure.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https://*.blob.core.windows.net; font-src 'self' data:; connect-src 'self' https://*.azurewebsites.net https://*.azure.com https://*.blob.core.windows.net; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
  },
  "mimeTypes": {
    ".json": "application/json",
    ".js": "text/javascript",
    ".css": "text/css",
    ".html": "text/html",
    ".png": "image/png",
    ".svg": "image/svg+xml",
    ".ico": "image/x-icon"
  },
  "roles": {
    "inventoryuser": {
      "provider": "aad"
    }
  },
  "platform": {
    "apiRuntime": "node:20"
  }
}

